 as job_run_completed_at,
            
    
        (date_diff(''second'', 
min(cast(run_started_at as timestamp))
::timestamp, 
max(cast(run_completed_at as timestamp))
::timestamp ))
    
 as job_run_execution_time
        from "manufacturing_command_center"."main"."dbt_invocations"

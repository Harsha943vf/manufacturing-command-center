        from "manufacturing_command_center"."main"."model_run_results"

        union all

        select
            model_execution_id,
            unique_id,
            invocation_id,
            name,
            generated_at,
            status,
            full_refresh,
            message,
            execution_time,
            execute_started_at,
            execute_completed_at,
            compile_started_at,
            compile_completed_at,
            compiled_code,
            database_name,
            schema_name,
            materialization,
            tags,
            package_name,
            path,
            original_path,
            owner,
            alias
        from "manufacturing_command_center"."main"."snapshot_run_results"
    )

select
    model_execution_id as alert_id,
    unique_id,
    cast(generated_at as timestamp) as detected_at,
    database_name,
    materialization,
    path,
    original_path,
    schema_name,
    message,
    owner as owners,
    tags,
    alias,
    status,
    full_refresh
from error_models
where
    
    
      (1 = 1)
    

    and lower(status) != 'success'and lower(status) != 'skipped'
  );


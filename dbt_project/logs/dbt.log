    current_timestamp::timestamp
,'dim_supplier_risk_score','OK','success','model',0.10218000411987305,'2026-06-20T17:31:00.647832Z','2026-06-20T17:31:00.731193Z','2026-06-20T17:31:00.633668Z','2026-06-20T17:31:00.643150Z',null,
